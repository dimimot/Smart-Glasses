# ==============================================================
# ROOT .gitignore — Smart Glasses VLM Project
# Covers: Python Server (v2/), Flutter App, Raspberry Pi scripts
# ==============================================================


# ── macOS system files ─────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db


# ── IDE / Editor ───────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws


# ── Python: compiled & cache ───────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
v2/__init__.pyc
v2/app/__init__.pyc


# ── Python: virtual environments & packaging ──────────────────
.venv/
venv/
env/
ENV/
dist/
*.egg-info/
.eggs/
*.egg


# ── Environment variables (ΠΟΤΕ δεν ανεβαίνει) ────────────────
# Το .env περιέχει secrets. Το .env.example ανεβαίνει κανονικά.
.env
.env.local
.env.production


# ── YOLO: model weights (μεγάλα binary αρχεία ~50MB+) ─────────
runs/
v2/app/runs/
v2/scripts/runs/
*.pt
*.pth
*.onnx
*.engine
*.bin
*.safetensors
*.gguf
v2/app/models/weights/
# Κράτα τον κενό φάκελο με .gitkeep ώστε να υπάρχει το directory
!v2/app/models/weights/.gitkeep


# ── Data: runtime / generated / sensitive ─────────────────────
# Εικόνες που φτάνουν από Raspberry Pi (runtime)
Data/received_images/*
!Data/received_images/.gitkeep

# Περιγραφές που παράγει το μοντέλο (runtime output)
Data/Generated_Text/*
!Data/Generated_Text/.gitkeep

# Debug εικόνες YOLO (runtime output)
Data/Output_image/*
!Data/Output_image/.gitkeep

# Timestamps CSV logs (runtime)
Data/logs/*
!Data/logs/.gitkeep

# Test/sample εικόνες (μεγάλα αρχεία)
# Αφαίρεσε αυτή τη γραμμή αν θέλεις να ανεβάσεις sample images
Data/Input_image/

# SSL certificates (ΠΟΤΕ δεν ανεβαίνουν — είναι secrets)
Data/certs/*.pem
Data/certs/*.key
Data/certs/*.crt
Data/certs/*.p12
# Το README.md μέσα στα certs ανεβαίνει (οδηγίες δημιουργίας)
!Data/certs/README.md


# ── Dev notes / internal docs (εσωτερικά) ─────────────────────
dev-help/


# ── Loose αρχεία που δεν ανήκουν στο repo ─────────────────────
# Παλιές εκδόσεις dart εκτός Flutter project structure
flutter_app/main.dart
flutter_app/main_older.dart
flutter_app/main_oldest.dart
sample output.txt


# ── Flutter: build artifacts (μεγάλα, auto-generated) ─────────
# Καλύπτει: flutter_app/tts_cam_test2/tts_cam_test2/
flutter_app/**/build/
flutter_app/**/coverage/
flutter_app/**/doc/api/

# Dart tool cache (auto-regenerated)
flutter_app/**/.dart_tool/

# Flutter plugin tracking (auto-regenerated — ΔΕΝ χρειάζονται στο repo)
flutter_app/**/.flutter-plugins
flutter_app/**/.flutter-plugins-dependencies

# Pub cache
flutter_app/**/.pub-cache/
flutter_app/**/.pub/

# Obfuscation / symbolication artifacts
flutter_app/**/app.*.symbols
flutter_app/**/app.*.map.json

# Build cache files
flutter_app/**/*.cache.dill.track.dill
flutter_app/**/last_build_run.json

# Android: machine-specific (περιέχει local SDK path)
flutter_app/**/local.properties
flutter_app/**/.gradle/
flutter_app/**/android/.gradle/
flutter_app/**/GeneratedPluginRegistrant.java

# Android build flavors
flutter_app/**/android/app/debug
flutter_app/**/android/app/profile
flutter_app/**/android/app/release

# Android / iOS signing (ΠΟΤΕ δεν ανεβαίνουν — secrets)
flutter_app/**/*.jks
flutter_app/**/key.properties

# iOS CocoaPods & Flutter iOS generated files
flutter_app/**/Podfile.lock
flutter_app/**/ios/Flutter/Generated.xcconfig
flutter_app/**/ios/Flutter/flutter_export_environment.sh
flutter_app/**/ios/Flutter/ephemeral/
flutter_app/**/ios/Flutter/App.framework
flutter_app/**/ios/Flutter/Flutter.framework
flutter_app/**/ios/Flutter/Flutter.podspec
flutter_app/**/ios/Flutter/flutter_assets/
flutter_app/**/ios/Flutter/app.flx
flutter_app/**/ios/Flutter/app.zip
flutter_app/**/ios/Runner/GeneratedPluginRegistrant.*
flutter_app/**/ios/.symlinks/
flutter_app/**/ios/Pods/
flutter_app/**/ios/DerivedData/
flutter_app/**/ios/xcuserdata/
flutter_app/**/ios/*.mode1v3
flutter_app/**/ios/*.mode2v3
flutter_app/**/ios/*.moved-aside
flutter_app/**/ios/*.pbxuser
flutter_app/**/ios/*.perspectivev3


# ── Misc ───────────────────────────────────────────────────────
flow.db
*.log
*.swp
*.class
.history
.svn/
migrate_working_dir/
